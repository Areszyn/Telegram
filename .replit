modules = ["nodejs-20", "bash", "web"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/miniapp/ PORT=3000 pnpm --filter @workspace/miniapp dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
MTPROTO_PORT = "3003"
APP_DOMAIN = "mini.susagar.sbs"
MINIAPP_URL = "https://lifegram-miniapp.pages.dev/"
WORKER_NAME = "lifegram-api"
ZONE_NAME = "susagar.sbs"
D1_DATABASE_NAME = "lifegram"
CF_PAGES_PROJECT = "lifegram-miniapp"
MTPROTO_API_KEY = "e04562be59a1e72ed326a1a96eaafe9933b5839f7da379eccc6ce16343860459"

[nix]
channel = "stable-25_05"
