# ============================================
# Lifegram Bot - Environment Variables
# ============================================
# Add all of these as Secrets in the Replit Secrets tab.
# Then run: bash scripts/deploy.sh
# The script auto-generates wrangler.toml and pushes
# all secrets to Cloudflare — no manual wrangler commands needed.
#
# To also deploy the Mini App, run:
#   DEPLOY_MINIAPP=true bash scripts/deploy.sh
# ============================================

# --- Telegram Bot ---
BOT_TOKEN=
ADMIN_ID=

# --- Telegram API (for MTProto) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=
D1_DATABASE_NAME=lifegram

# --- Cloudflare R2 Storage ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- OxaPay Crypto Payments ---
OXAPAY_MERCHANT_KEY=

# --- MTProto Backend ---
MTPROTO_API_KEY=
MTPROTO_PORT=3003

# --- Domain Config ---
APP_DOMAIN=mini.susagar.sbs
MINIAPP_URL=https://lifegram-miniapp.pages.dev/
WORKER_NAME=lifegram-api
ZONE_NAME=susagar.sbs
CF_PAGES_PROJECT=lifegram-miniapp

# --- After Deploying Replit (auto-set by deploy script if available) ---
# MTPROTO_BACKEND_URL=https://your-replit-app.replit.app
